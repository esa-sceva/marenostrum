Bootstrap: docker
From: python:3.12

%post
    chmod 755 /root
    python3 --version
    apt update
    apt install -y  curl
    # Install uv
    curl -LsSf https://astral.sh/uv/install.sh | sh
    # Add uv to PATH
    export PATH=/root/.local/bin:$PATH
    # Install Rust
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
    # Add Rust to PATH
    export PATH="$HOME/.cargo/bin:$PATH"
    python3 --version
    git clone https://github.com/esa-satcomllm/satcom-synthetic-data-gen.git
    cd satcom-synthetic-data-gen
    cd synthetic_gen
    uv venv --python 3.12
    . .venv/bin/activate
    
    # Try latest CUDA versions for PyTorch 2.6+
    uv pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu124 || \
    uv pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu123 || \
    uv pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu121
    
    uv pip install -r requirements.txt
    uv pip install pyarrow
    uv pip install bitsandbytes
    uv pip install vllm

    # Download NLTK data
    . .venv/bin/activate
    python -c "
import nltk
import ssl
try:
    _create_unverified_https_context = ssl._create_unverified_context
except AttributeError:
    pass
else:
    ssl._create_default_https_context = _create_unverified_https_context

# Download required NLTK data
nltk.download('punkt')
nltk.download('punkt_tab')
print('NLTK data downloaded successfully')

# Quick GPU PyTorch verification
print('Verifying GPU PyTorch installation...')
import torch
print(f'PyTorch version: {torch.__version__}')
print(f'CUDA compiled: {torch.version.cuda}')
if torch.version.cuda:
    print('SUCCESS: GPU PyTorch installed correctly!')
else:
    print('ERROR: CPU-only PyTorch detected!')
"

    # Create workdir
    mkdir workspace

%environment
    export PATH=/root/.local/bin:$PATH
    export PATH="$HOME/.cargo/bin:$PATH"
    export SINGULARITY_BIND="/gpfs/projects/<project_id>/satcom:/workspace"
    export HF_HOME=/workspace/hf_cache
