Bootstrap: docker
From: python:3.12

%post
    chmod 755 /root
    python3 --version
    apt update
    apt install -y  curl
    # Install uv
    curl -LsSf https://astral.sh/uv/install.sh | sh
    # Add uv to PATH
    export PATH=/root/.local/bin:$PATH
    # Install Rust
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
    # Add Rust to PATH
    export PATH="$HOME/.cargo/bin:$PATH"
    python3 --version
    git clone https://github.com/esa-satcomllm/satcom-synthetic-data-gen.git
    cd satcom-synthetic-data-gen
    cd synthetic_gen
    uv venv --python 3.12
    uv pip install -r requirements.txt
    uv pip install vllm --torch-backend=auto
    uv pip install pyarrow

    # Create workdir
    mkdir workspace

%environment
    export PATH=/root/.local/bin:$PATH
    export PATH="$HOME/.cargo/bin:$PATH"
    export SINGULARITY_BIND="/gpfs/project/<project_id>/satcom:/workspace"
    export HF_HOME=/workspace/hf_cache
