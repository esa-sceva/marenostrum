#!/bin/bash
#SBATCH --job-name=test_synth_gen
#SBATCH -D .
#SBATCH --output=slurm_out/mpi_%j.out
#SBATCH --error=slurm_out/mpi_%j.err
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=20
#SBATCH --time=00:15:00
#SBATCH --gres=gpu:1

export SRUN_CPUS_PER_TASK=${SLURM_CPUS_PER_TASK}
echo "Job ID: $SLURM_JOB_ID"
echo "Node: $SLURMD_NODENAME"
echo "Timestamp: $(date)"

module load singularity

CONFIG_PATH="$1"
PIPELINE="$2"
OUTPUT_DIR="$3"

if [[ -z "$CONFIG_PATH" || -z "$PIPELINE" || -z "$OUTPUT_DIR" ]]; then
    echo "Usage: sbatch my_slurm_script.sh <config_path> <pipeline> <output_dir>"
    exit 1
fi

echo "Running with:"
echo "- Config path: $CONFIG_PATH"
echo "- Pipeline: $PIPELINE"
echo "- Output dir: $OUTPUT_DIR"

singularity exec --nv container.sif /bin/bash /gpfs/projects/<project_id>/myfolder/run.sh "$CONFIG_PATH" "$PIPELINE" "$OUTPUT_DIR"

echo "Job completed at $(date)"
