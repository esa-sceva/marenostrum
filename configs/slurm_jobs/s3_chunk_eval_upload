PROMPT_TEMPLATE="./evaluators/prompts/ultraRM_prompt.yaml"
OUTPUT_DESTINATION="output"
OUTPUT_TYPE="local"
SCORE_THRESHOLD="-12"
MAX_CHUNK_SIZE="4096"
LOCAL_JSON_PATH="./selected_chunks_scores.json"
LOGS_FOLDER="logs"

# Model loading mode (1 = offline, 0 = online)
OFFLINE_MODE=1
