# SLURM directives
JOB_NAME=s3_chunk_eval_upload
WORK_DIR=.
OUT_FILE=slurm_out/mpi_%j.out
ERR_FILE=slurm_out/mpi_%j.err
NTASKS=1
CPUS_PER_TASK=40
TIME=00:50:00
GRES=gpu:2

# SLURM submission options
ACCOUNT=<project_id>
QOS=acc_debug

# Job-specific arguments
INPUT_SOURCE="/workspace/satcom-synthetic-data-gen/data"
