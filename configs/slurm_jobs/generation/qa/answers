# SLURM directives for Answer Generation with vLLM
JOB_NAME=wikipedia
WORK_DIR=.
OUT_FILE=slurm_out_answer_generation/answer_gen_wikipedia_%j.out
ERR_FILE=slurm_out_answer_generation/answer_gen_wikipedia_%j.err
VLLM_LOG_FILE=slurm_out_answer_generation/answer_gen_wikipedia_%j_vllm_server.log
NTASKS=1
CPUS_PER_TASK=80
TIME=12:00:00
GRES=gpu:4

# SLURM submission options
ACCOUNT=<project_id>
QOS=acc_ehpc

# Job-specific arguments for Answer Generation
MODEL_NAME="llama3.3-70B"
QUESTIONS_FILE="/gpfs/projects/<project_id>/myfolder/questions/wikipedia_questions.jsonl"
INPUT_SOURCE="/gpfs/scratch/<project_id>/myfolder/data/wikipedia/"
INPUT_TYPE="local"
OUTPUT_TYPE="local"
PROMPT_PATH="/satcom-synthetic-data-gen/synthetic_gen/generators/prompts/answer_from_question.yaml"
RESULTS_FILE="/gpfs/projects/<project_id>/myfolder/answers/qa_answers_wikipedia.jsonl"
N_DOCS="-1"
N_SHOTS="2"
TEMPERATURE="0.1"
MAX_RETRIES="3"
BACKEND="vllm"
NUM_WORKERS="8"
VLLM_URL="http://localhost:8000/v1"
S3_BUCKET=""

